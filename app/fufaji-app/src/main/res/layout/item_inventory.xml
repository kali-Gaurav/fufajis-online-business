<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Product Emoji -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@color/light_gray"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/productEmojiText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textSize="32sp" />
        </FrameLayout>

        <!-- Product Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/productNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/productCategoryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="12dp"
                    android:background="@color/divider_color"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/productPriceText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹100"
                    android:textSize="11sp"
                    android:textColor="@color/primary_color"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Stock Status -->
            <TextView
                android:id="@+id/stockStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Stock (10)"
                android:textSize="11sp"
                android:textColor="@color/in_stock"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Stock Control -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginStart="8dp">

            <!-- Stock Input -->
            <EditText
                android:id="@+id/stockInputText"
                android:layout_width="50dp"
                android:layout_height="32dp"
                android:text="10"
                android:inputType="number"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/quantity_background"
                android:layout_marginBottom="4dp" />

            <!-- +/- Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/decreaseStockButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="Decrease"
                    android:background="@android:color/transparent"
                    android:scaleType="centerInside"
                    android:tint="@color/text_primary"
                    android:layout_marginEnd="2dp" />

                <ImageButton
                    android:id="@+id/increaseStockButton"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_input_add"
                    android:contentDescription="Increase"
                    android:background="@android:color/transparent"
                    android:scaleType="centerInside"
                    android:tint="@color/text_primary"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- Save Button -->
            <ImageButton
                android:id="@+id/saveStockButton"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_save"
                android:contentDescription="Save"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:tint="@color/success_color"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/editButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Edit"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:tint="@color/accent_color"
                android:layout_marginBottom="4dp" />

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="Delete"
                android:background="@android:color/transparent"
                android:scaleType="centerInside"
                android:tint="@color/error_color" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>


