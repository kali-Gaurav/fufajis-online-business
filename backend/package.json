{
  "name": "fufaji-backend",
  "version": "1.0.0",
  "description": "Fufaji backend on AWS Lambda (Function URL). Ported from Firebase Functions.",
  "main": "src/lambda.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "sam build",
    "deploy": "sam deploy --guided",
    "deploy:fast": "sam build && sam deploy --no-confirm-changeset",
    "local": "sam local start-lambda"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.620.0",
    "@aws-sdk/client-ssm": "^3.620.0",
    "@aws-sdk/s3-request-presigner": "^3.620.0",
    "@genkit-ai/googleai": "^0.9.11",
    "@google-cloud/speech": "^6.1.0",
    "@google/generative-ai": "^0.21.0",
    "@sendgrid/mail": "^8.1.3",
    "@supabase/supabase-js": "^2.43.0",
    "axios": "^1.7.2",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "firebase-admin": "^12.3.1",
    "genkit": "^0.9.11",
    "serverless-http": "^3.2.0",
    "twilio": "^5.0.0",
    "zod": "^3.23.8"
  },
  "private": true
