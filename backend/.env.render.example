# ============================================================================
# .env.render - Render Backend Environment Variables
# ============================================================================
# Copy these to Render Dashboard → Environment tab
# DO NOT commit secrets to git

# ── API CONFIGURATION ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_BASE_URL=https://fufajis-online-business.onrender.com

# ── DATABASE ────────────────────────────────────────────────────────────
# Supabase PostgreSQL Connection
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── FIREBASE (Backend Admin) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=fufaji-online-business
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"fufaji-online-business","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ── RAZORPAY PAYMENT GATEWAY ────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret-here
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ── COMMUNICATIONS ─────────────────────────────────────────────────────
# WhatsApp Business API
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-id
WHATSAPP_ENABLED=true

# Twilio SMS
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+91xxxxxxxxxx

# SendGrid Email
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@fufajionline.com

# ── AI & ANALYTICS ──────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
SENTRY_DSN=https://your-sentry-dsn

# ── AWS S3 (Optional) ───────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=fufaji-uploads

# ── SHOP CONFIGURATION ──────────────────────────────────────────────────
SHOP_LATITUDE=25.1006
SHOP_LONGITUDE=76.5156
SHOP_PHONE=+91-9876543210
DELIVERY_RADIUS_KM=15

# ── FEATURE FLAGS ───────────────────────────────────────────────────────
WHATSAPP_ENABLED=true
AI_PRICING_ENABLED=true
CHATBOT_ENABLED=true
DELIVERY_TRACKING_ENABLED=true

# ── CRON JOB SCHEDULE ───────────────────────────────────────────────────
# Times in UTC (convert to IST: add 5:30 hours)
CRON_PROCESS_SUBSCRIPTIONS=0 0 * * * # Daily at 00:00 UTC (05:30 IST)
CRON_CALCULATE_COMMISSIONS=0 1 * * * # Daily at 01:00 UTC (06:30 IST)
CRON_CLEANUP_RESERVATIONS=*/30 * * * * # Every 30 minutes
CRON_RECONCILE_PAYMENTS=0 * * * * # Hourly at minute 0

# ── LOGGING ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── RATE LIMITING ───────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15 # minutes
RATE_LIMIT_MAX_REQUESTS=100 # per window
