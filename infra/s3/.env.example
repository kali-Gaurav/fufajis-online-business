# Copy to .env and fill in. Use the SAME values configured for the
# Cloud Functions S3 proxy (functions.config().aws.*) — see
# functions/aws_services.js. Never commit .env.

AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET=bucket-ofqh8w

# Optional: only set if using a non-AWS S3-compatible endpoint
# (matches functions.config().aws.s3_endpoint, without the scheme).
# AWS_S3_ENDPOINT=s3.ap-south-1.amazonaws.com
