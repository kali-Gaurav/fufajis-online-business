{
  "_comment": "S3 bucket lifecycle configuration for the Fufaji Store bucket (default: bucket-ofqh8w, region ap-south-1). Applied via apply_lifecycle_policy.js using PutBucketLifecycleConfiguration. Prefixes correspond to S3Paths in lib/services/s3_storage_service.dart. See docs/S3_LIFECYCLE_POLICY.md for rationale per rule.",
  "Rules": [
    {
      "ID": "abort-incomplete-multipart-uploads",
      "Status": "Enabled",
      "Filter": {},
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 7
      }
    },
    {
      "ID": "backups-expire-and-tier",
      "Status": "Enabled",
      "Filter": { "Prefix": "backups/" },
      "Transitions": [
        { "Days": 30, "StorageClass": "STANDARD_IA" }
      ],
      "Expiration": { "Days": 90 },
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 7 }
    },
    {
      "ID": "user-docs-tier-to-ia",
      "Status": "Enabled",
      "Filter": { "Prefix": "users/" },
      "Transitions": [
        { "Days": 180, "StorageClass": "STANDARD_IA" }
      ]
    },
    {
      "ID": "order-financial-docs-tier-to-ia",
      "Status": "Enabled",
      "Filter": { "Prefix": "orders/" },
      "Transitions": [
        { "Days": 180, "StorageClass": "STANDARD_IA" }
      ]
    },
    {
      "ID": "marketing-assets-expire-and-tier",
      "Status": "Enabled",
      "Filter": { "Prefix": "marketing/" },
      "Transitions": [
        { "Days": 30, "StorageClass": "STANDARD_IA" }
      ],
      "Expiration": { "Days": 365 },
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 7 }
    },
    {
      "ID": "product-and-vendor-media-intelligent-tiering",
      "Status": "Enabled",
      "Filter": { "Prefix": "products/" },
      "Transitions": [
        { "Days": 0, "StorageClass": "INTELLIGENT_TIERING" }
      ]
    },
    {
      "ID": "vendor-media-intelligent-tiering",
      "Status": "Enabled",
      "Filter": { "Prefix": "vendors/" },
      "Transitions": [
        { "Days": 0, "StorageClass": "INTELLIGENT_TIERING" }
      ]
    },
    {
      "ID": "orphaned-staging-uploads-expire",
      "Status": "Enabled",
      "Filter": { "Prefix": "uploads/" },
      "Expiration": { "Days": 45 },
      "AbortIncompleteMultipartUpload": { "DaysAfterInitiation": 7 }
    }
  ]
}
