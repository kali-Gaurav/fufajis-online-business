# ============================================================
# Firestore -> Postgres migration — environment configuration
#
# Copy this file to `.env` in the same folder and fill in real
# values. NEVER commit the real `.env` file.
# ============================================================

# --- Firebase Admin -----------------------------------------
# Path to a Firebase service account JSON key (Project Settings
# > Service Accounts > Generate new private key).
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# --- Postgres / Supabase -------------------------------------
# Use the Supabase "Connection string" (Session/Transaction
# pooler is fine for this batch job). Must be a role with
# INSERT/UPDATE access to all tables listed in 001_core_schema.sql.
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# --- Batch tuning ---------------------------------------------
# Number of Firestore docs read per page (firestore pagination).
MIGRATION_BATCH_SIZE=200

# Number of rows per Postgres multi-row upsert statement.
MIGRATION_PG_CHUNK_SIZE=100
