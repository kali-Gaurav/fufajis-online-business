# ================================================================
# Fufaji's Online — Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is already in .gitignore.
# ================================================================

# ── API & Base Config ──────────────────────────────────────────
API_BASE_URL=https://fufaji-api.render.com
NODE_ENV=development

# ── Razorpay (Payments) ────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ── WhatsApp Business API ─────────────────────────────────────
WHATSAPP_TOKEN=xxxxxxxxxxxxxxxx
WHATSAPP_PHONE_ID=xxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=xxxxxxxxxxxxxxxx

# ── Google Cloud / Firebase ───────────────────────────────────
GOOGLE_MAPS_KEY=xxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxx

# ── Sentry (Error Tracking) ──────────────────────────────────
SENTRY_DSN=xxxxxxxxxxxxxxxx

# ── AWS / Supabase Storage ────────────────────────────────────
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
AWS_REGION=ap-south-1
SUPABASE_S3_ACCESS_KEY=xxxxxxxxxxxxxxxx
SUPABASE_S3_SECRET_KEY=xxxxxxxxxxxxxxxx
SUPABASE_URL=xxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxx

# ── Database (Postgres / RDS) ─────────────────────────────────
RDS_CONNECTION_STRING=xxxxxxxxxxxxxxxx
RDS_HOST=xxxxxxxxxxxxxxxx
RDS_PORT=5432
RDS_USER=postgres
RDS_PASSWORD=xxxxxxxxxxxxxxxx
RDS_DATABASE=postgres

# ── Caching (Upstash Redis) ──────────────────────────────────
UPSTASH_REDIS_REST_URL=xxxxxxxxxxxxxxxx
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# ── Android Signing (Keystore) ────────────────────────────────
ANDROID_STORE_PASSWORD=xxxxxxxxxxxxxxxx
ANDROID_KEY_PASSWORD=xxxxxxxxxxxxxxxx
ANDROID_KEY_ALIAS=upload
ANDROID_STORE_FILE=fufaji-upload-key.jks

# ── Twilio (SMS) ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=xxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=xxxxxxxxxxxxxxxx

# ── Stripe (Fallback Payments) ────────────────────────────────
STRIPE_PUBLISHABLE_KEY=xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=xxxxxxxxxxxxxxxx

# ── App Info ──────────────────────────────────────────────────
SUPPORT_WHATSAPP_NUMBER=+91XXXXXXXXXX
APK_DOWNLOAD_URL=https://github.com/your-user/fufaji-online-business/releases/download
