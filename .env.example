# ================================================================
# Fufaji's Online — Environment Variables Template
# ================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is already in .gitignore.
# NEVER list .env in pubspec.yaml assets (secret exposure in APK).
#
# SECURITY RULES:
# - LIVE_KEY_SECRET must NEVER be in the Flutter app.
#   It is only used in Firebase Cloud Functions.
# - After any accidental exposure, rotate keys immediately.
# ================================================================

# ── Razorpay ──────────────────────────────────────────────────
# Public key (OK to be in app — used to open Razorpay SDK)
LIVE_API_KEY=rzp_live_YOUR_PUBLIC_KEY_HERE

# SECRET KEY — DO NOT PUT IN FLUTTER APP
# This value is only set in Firebase Functions config:
#   firebase functions:config:set razorpay.key_secret="YOUR_SECRET"
# LIVE_KEY_SECRET=DO_NOT_USE_IN_APP

# ── Firebase Test Token (for testing push notifications) ──────
FIREBASE_TEST_TOKEN=

# ── WhatsApp Business API ─────────────────────────────────────
# Only used server-side in Firebase Functions
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# ── Gemini AI (optional — for AI search features) ─────────────
# GEMINI_API_KEY=

# ── Twilio SMS (only used server-side in Firebase Functions) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=

# ── Upstash Redis (optional — for lightning deals caching) ────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
