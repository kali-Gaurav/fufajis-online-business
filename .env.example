# 🔐 Fufaji Environment Variables
# Copy this file to .env and fill in your actual values
# NOTE: .env is NEVER included in release builds for security

# ── Backend API ──────────────────────────────────────
# URL of your Render backend that serves /config/app-config
API_BASE_URL=https://fufajis-online-business.onrender.com

# ── Supabase PostgreSQL ──────────────────────────────
# Get these from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Razorpay Payments ────────────────────────────────
# Get live key from https://dashboard.razorpay.com/settings/api-keys
# IMPORTANT: Use rzp_live_* for production, rzp_test_* for testing
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxx

# ── Google Maps API ─────────────────────────────────
# Get from Google Cloud Console (Maps SDK for Android & Web)
GOOGLE_MAPS_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry Error Tracking (Optional) ─────────────────
# Get DSN from https://sentry.io (optional for error tracking)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ── Firebase (Already configured in firebase_options.dart) ──
# No need to add here - credentials are in the code

# ── Shop Configuration (Optional) ───────────────────
# Used as fallback if Supabase is unavailable
SHOP_LATITUDE=25.1006
SHOP_LONGITUDE=76.5156
MAX_DELIVERY_RADIUS=15

# ── Feature Flags ────────────────────────────────────
WHATSAPP_ENABLED=true
APK_DOWNLOAD_URL=https://your-domain.com/download/fufaji.apk
SUPPORT_WHATSAPP_NUMBER=+91xxxxxxxxxx
