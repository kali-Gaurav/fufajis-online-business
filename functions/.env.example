# Razorpay Webhook Configuration
# ============================================================================
# Obtain these from your Razorpay Dashboard: https://dashboard.razorpay.com

# Your Razorpay API Key (Key ID)
# Location: Dashboard > Settings > API Keys
RAZORPAY_API_KEY=rzp_live_xxxxxxxxxxxxx

# Your Razorpay API Secret (Key Secret)
# Location: Dashboard > Settings > API Keys
RAZORPAY_API_SECRET=xxxxxxxxxxxxxxxx

# Webhook Signing Secret
# Location: Dashboard > Settings > Webhooks
# Used for HMAC-SHA256 signature validation
RAZORPAY_WEBHOOK_SECRET=webhook_secret_xxxxxxxx


# Firebase Configuration
# ============================================================================

# Your Firebase project ID
FIREBASE_PROJECT_ID=fufaji-store

# These are automatically configured by Firebase when deployed
# But can be set here for local development
FIREBASE_DATABASE_URL=https://fufaji-store.firebaseio.com
FIREBASE_AUTH_DOMAIN=fufaji-store.firebaseapp.com


# Webhook Configuration
# ============================================================================

# Maximum number of retry attempts for failed payments
# Default: 3
PAYMENT_RETRY_MAX_ATTEMPTS=3

# Initial retry delay in milliseconds (5 minutes)
# Default: 300000 (5 minutes)
PAYMENT_RETRY_INITIAL_DELAY_MS=300000

# Exponential backoff multiplier for retries
# Each retry = delay * multiplier ^ attempt
# Default: 2 (5 min, 10 min, 20 min)
PAYMENT_RETRY_BACKOFF_MULTIPLIER=2


# Logging Configuration
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable detailed webhook payload logging (not recommended for production)
ENABLE_WEBHOOK_PAYLOAD_LOGGING=false


# Application Configuration
# ============================================================================

# Environment: development, staging, production
NODE_ENV=production

# Application name
APP_NAME=Fufaji Store
