rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      let role = getUserData().role;
      return role == roleName || role == ('UserRole.' + roleName);
    }

    function isGlobalAdmin() {
      return hasRole('owner') || hasRole('superAdmin') || hasRole('franchiseOwner');
    }

    function isSupplier() { return hasRole('supplier'); }
    function isBranchManager() { return hasRole('branchManager'); }
    function getBranchId() { return getUserData().branchId; }

    match /delivery_proofs/{orderId}/{allPaths=**} {
      // Riders upload proofs, customers can see their own (assuming order ownership), admins can see all
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && hasRole('rider');
    }

    match /profile_images/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isGlobalAdmin());
    }

    match /invoice_pdfs/{orderId}/{allPaths=**} {
      allow read: if isSignedIn(); // Customer or admins. (Ideally check order ownership, but simplified for PDF read)
      allow write: if isSignedIn() && isGlobalAdmin();
    }

    match /supplier_documents/{supplierId}/{allPaths=**} {
      allow read: if isSignedIn() && (isGlobalAdmin() || (isSupplier() && request.auth.uid == supplierId));
      allow write: if isSignedIn() && (isGlobalAdmin() || (isSupplier() && request.auth.uid == supplierId));
    }

    match /contracts/{contractId}/{allPaths=**} {
      allow read: if isSignedIn() && (isGlobalAdmin() || isSupplier());
      allow write: if isSignedIn() && isGlobalAdmin();
    }

    // Fallback: restrict unmatched paths to staff read, admin write
    match /{allPaths=**} {
      allow read: if isSignedIn() && (isGlobalAdmin() || isBranchManager());
      allow write: if isSignedIn() && isGlobalAdmin();
    }
  }
}
