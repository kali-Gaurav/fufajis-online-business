rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner() {
      return isSignedIn() && getUser().role == 'UserRole.shopOwner';
    }
    
    function isRider() {
      return isSignedIn() && getUser().role == 'UserRole.deliveryAgent';
    }

    function isEmployee() {
      return isSignedIn() && (
        getUser().role in ['UserRole.employee', 'UserRole.shopOwner', 'UserRole.admin']
      );
    }

    function isAdmin() {
      return isSignedIn() && getUser().role == 'UserRole.admin';
    }

    // Check if an order is in a terminal (immutable) state
    function isOrderTerminal(orderData) {
      return orderData.status in [
        'OrderStatus.delivered',
        'OrderStatus.cancelled',
        'OrderStatus.refunded'
      ];
    }

    function getShopConfig() {
      return get(/databases/$(database)/documents/settings/shop_config).data;
    }

    function isWithinGeofence(address) {
      let config = getShopConfig();
      // Validate required fields
      return address.latitude != null 
             && address.longitude != null
             && config.shopLatitude != null
             && config.shopLongitude != null
             && config.maxDeliveryRadiusKm != null
             && distance([address.latitude, address.longitude], 
                        [config.shopLatitude, config.shopLongitude]) 
                <= config.maxDeliveryRadiusKm;
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Enhanced read permissions: Only self, staff, or admin
      allow read: if isSignedIn() && (
        request.auth.uid == userId 
        || isEmployee() 
        || isAdmin()
      );

      // Strict role protection: Cannot change own role
      allow update: if isSignedIn() 
                     && request.auth.uid == userId
                     && request.resource.data.role == resource.data.role
                     && !('roles' in request.resource.data.keys())
                     && !('shopIds' in request.resource.data.keys());
      
      // Create: Only customers by default, or pre-authorized roles
      allow create: if isSignedIn() 
                     && request.auth.uid == userId
                     && request.resource.data.role == 'UserRole.customer'
                     && !('shopIds' in request.resource.data.keys())
                     && !('roles' in request.resource.data.keys());

      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /wallet_transactions/{transactionId} {
        allow read: if isSignedIn() && (
          request.auth.uid == userId || isEmployee() || isAdmin()
        );
        allow create: if isSignedIn() 
                       && request.auth.uid == userId
                       && request.resource.data.amount > 0
                       && request.resource.data.amount < 1000000;  // Max ₹10L
        allow update, delete: if false;  // Immutable
      }

      match /notifications/{notificationId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow write: if false;  // Backend only
      }
    }

    // --- Pre-Authorized Users (RESTRICTED) ---
    match /pre_authorized_users/{phone} {
      // FIXED: Only admin can read (was: allow get: if true)
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Audit Logs (APPEND-ONLY) ---
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;  // Immutable
    }

    // --- Products Collection (WITH PRICING PROTECTION) ---
    match /products/{productId} {
      // FIXED: Products visible only within geofence
      allow read: if isSignedIn() && (
        // Customers: only if within geofence
        (getUser().role == 'UserRole.customer' && isWithinGeofence(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.currentAddress ?? {}))
        // Staff: always readable
        || isEmployee()
        || isAdmin()
      );
      allow write: if isOwner() || isAdmin();

      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                       && request.resource.data.userId == request.auth.uid
                       && request.resource.data.rating >= 1
                       && request.resource.data.rating <= 5
                       && request.resource.data.text.size() <= 500;
        allow update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      allow create: if isSignedIn()
                     && request.resource.data.customerId == request.auth.uid
                     && request.resource.data.status == 'OrderStatus.pending'
                     && request.resource.data.paymentStatus in ['pending', 'null']
                     && isWithinGeofence(request.resource.data.deliveryAddress)
                     && request.resource.data.totalAmount > 0
                     && request.resource.data.totalAmount < 100000;  // Max ₹1L
                     
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.customerId
        || isOwner()
        || isRider()
        || isAdmin()
      );
      
      // FIXED: Enhanced immutability guard
      allow update: if isSignedIn()
        && (
          // Admin override for refunds ONLY
          (isAdmin() && 'refundAmount' in request.resource.data.keys())
          ||
          // Owner/Employee can update non-terminal orders
          ((isOwner() || isEmployee()) 
           && !isOrderTerminal(resource.data)
           && !('customerId' in request.resource.data.diff(resource.data).affectedKeys())
           && !('totalAmount' in request.resource.data.diff(resource.data).affectedKeys()))
          ||
          // Rider can update only assigned orders
          (isRider() 
           && resource.data.deliveryAgentId == request.auth.uid
           && !isOrderTerminal(resource.data)
           && resource.data.status in ['OrderStatus.confirmed', 'OrderStatus.packed', 'OrderStatus.outForDelivery'])
          ||
          // Customer can ONLY cancel pending/confirmed orders
          (request.auth.uid == resource.data.customerId
           && !isOrderTerminal(resource.data)
           && resource.data.status in ['OrderStatus.pending', 'OrderStatus.confirmed', 'OrderStatus.accepted']
           && request.resource.data.status == 'OrderStatus.cancelled'
           && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'statusHistory', 'cancellationReason']))
        );

      allow delete: if false;  // Orders never deleted

      match /secure/otp {
        allow read: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/orders/$(orderId)).data.customerId;
        allow create, update: if isOwner() || isAdmin() || isRider();
        allow delete: if false;
      }
    }

    // --- Payments (APPEND-ONLY AUDIT TRAIL) ---
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        isOwner() || isAdmin() || request.auth.uid == resource.data.customerId
      );
      allow create: if isSignedIn() 
                     && request.resource.data.customerId == request.auth.uid
                     && request.resource.data.amount > 0
                     && request.resource.data.amount < 100000
                     && request.resource.data.status == 'pending';
      allow update: if isOwner() || isAdmin();
      allow delete: if false;  // Immutable
    }

    // --- Return Requests ---
    match /return_requests/{requestId} {
      allow read: if isSignedIn() && (
        isOwner() || isAdmin() || request.auth.uid == resource.data.customerId
      );
      allow create: if isSignedIn() && request.resource.data.customerId == request.auth.uid;
      allow update: if (isOwner() || isAdmin());
      allow delete: if false;  // Immutable
    }

    // --- Chat (WITH PARTICIPANT VALIDATION) ---
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid in request.resource.data.participants
      );
    }

    // --- Settings ---
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isOwner() || isAdmin();

      match /branches/{branchId} {
        allow read: if isSignedIn();
        allow write: if isOwner() || isAdmin();
      }
    }

    // --- Rider Payouts ---
    match /rider_payouts/{payoutId} {
      allow read: if isSignedIn() && (
        isOwner() || isAdmin() || request.auth.uid == resource.data.riderId
      );
      allow write: if isOwner() || isAdmin();
    }

    // --- Payment Reconciliation (APPEND-ONLY) ---
    match /payment_reconciliation_log/{logId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;  // Immutable
    }

    // --- Cash Collection Audit (APPEND-ONLY) ---
    match /cash_collection_audit/{logId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isSignedIn() && (isRider() || isEmployee() || isOwner() || isAdmin());
      allow update, delete: if false;  // Immutable
    }

    // --- Webhook Events (SYSTEM ONLY) ---
    match /webhook_events/{eventId} {
      allow read, write: if false;  // Backend only
    }

    // --- Group Buying Pools ---
    match /group_pools/{poolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                     && request.resource.data.creatorId == request.auth.uid
                     && request.resource.data.memberIds.size() <= 100;
      allow update: if isSignedIn() 
                     && (request.auth.uid == resource.data.creatorId 
                         || request.auth.uid in resource.data.memberIds);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.creatorId;
    }

    // --- Khata Transactions ---
    match /khata_transactions/{transactionId} {
      allow read: if isSignedIn() && (
        isOwner() || isAdmin() || request.auth.uid == resource.data.userId
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid || isOwner() || isAdmin()
      );
      allow update, delete: if isOwner() || isAdmin();
    }

    // --- Shops & Inventory ---
    match /shops/{shopId} {
      allow read: if isSignedIn();
      allow write: if isOwner() || isAdmin();

      match /branches/{branchId} {
        allow read: if isSignedIn();
        allow write: if isOwner() || isAdmin();

        match /products/{productId} {
          allow read: if isSignedIn();
          allow write: if isOwner() || isAdmin() || isEmployee();
        }

        match /inventory_batches/{batchId} {
          allow read: if isSignedIn();
          allow write: if isOwner() || isAdmin() || isEmployee();
        }

        match /inventory_audit_logs/{auditId} {
          allow read: if isEmployee() || isOwner() || isAdmin();
          allow create: if isEmployee() || isOwner() || isAdmin();
          allow update, delete: if false;
        }

        match /orders/{orderId} {
          allow read: if isSignedIn();
          allow write: if isOwner() || isAdmin() || isEmployee();
        }
      }
    }
  }
}